# Copy this file to .env.local and fill in values from your Supabase project
# (Supabase Dashboard → Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Demo account for the "ลองเล่นโหมด Demo" button (used from Phase 1)
DEMO_EMAIL=demo@pawmate.app
DEMO_PASSWORD=change-me

# Client-visible (NEXT_PUBLIC_) list of demo logins that get an unlimited,
# recycling swipe deck so shared-demo testers never run out of cards.
# Comma-separated. Optional — code falls back to these same defaults if unset.
NEXT_PUBLIC_DEMO_EMAIL=demo@pawmate.app,demo-full@pawmate.app
